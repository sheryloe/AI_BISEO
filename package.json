{
  "name": "ai_biseo",
  "version": "0.1.0",
  "description": "AI_BISEO 메인 컨트롤러",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:smoke:phase1": "tsx scripts/smoke-test-phase1.ts",
    "n8n:patch:ai-writer-openai": "tsx scripts/patch-n8n-ai-writer-openai.ts",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f ai_biseo_server",
    "notion:push:bootstrap": "npm run notion:push:workspace",
    "notion:push:workspace": "tsx scripts/push-bootstrap-worklogs-to-notion.ts"
  },
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.86.2",
    "socket.io": "^4.8.1",
    "telegraf": "^4.16.3",
    "zod": "^3.24.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
